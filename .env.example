# Copy this file to .env and fill in your hosting details.
# Keep .env private. It is ignored by Git.

# Use ftp or ftps. Prefer ftps if your host supports it.
FTP_PROTOCOL=ftps

# Host only, without ftp:// or ftps://
FTP_HOST=example.com

# Optional. Use this when the FTPS certificate hostname differs from the domain,
# but your host gives you a fixed FTP server IP.
FTP_RESOLVE_IP=

FTP_USER=your-ftp-username
FTP_PASSWORD=your-ftp-password

# Full remote path to the plugin folder on the server.
# Common examples:
# /public_html/wp-content/plugins/barnahus-site-tools
# /www/wp-content/plugins/barnahus-site-tools
# /htdocs/wp-content/plugins/barnahus-site-tools
FTP_REMOTE_PLUGIN_DIR=/public_html/wp-content/plugins/barnahus-site-tools
